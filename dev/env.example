# Copy this file to dev/.env and fill in your values.
# dev/.env is gitignored — never commit credentials.
#
# Usage:
#   cp dev/env.example dev/.env
#   $EDITOR dev/.env
#   docker compose -f dev/docker-compose.yml up --build

UNIFI_HOST=https://unifi.home.arpa
UNIFI_API_KEY=your-api-key-here
UNIFI_SITE=default
UNIFI_SKIP_TLS_VERIFY=true
# UNIFI_CA_CERT=/path/to/ca.pem   # use instead of SKIP_TLS_VERIFY with a real cert

METRICS_ADDR=:9090
